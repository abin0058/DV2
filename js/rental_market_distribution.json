{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 550,
  "title": {
    "text": "Australian Rental Market Geographic Distribution (2026)",
    "fontSize": 16,
    "anchor": "start",
    "offset": 20
  },
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "description": "Base layer: Map of Australia from TopoJSON",
      "data": {
        "url": "maps/ne.json",
        "format": {
          "type": "topojson",
          "feature": "ne_50m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.admin === 'Australia'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#f4f4f4",
        "stroke": "#bcbcbc",
        "strokeWidth": 0.6
      }
    },
    {
      "description": "Data layer: Rental properties plotted by Latitude and Longitude",
      "data": {
        "url": "data/australian_rental_market_2026.csv",
        "format": {
          "type": "csv"
        }
      },
      "mark": {
        "type": "circle",
        "opacity": 0.6,
        "size": 20
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "color": {
          "field": "price_display",
          "type": "quantitative",
          "title": "Weekly Rent ($ AUD)",
          "scale": {
            "scheme": "viridis",
            "domain": [300, 1500],
            "clamp": true
          }
        },
        "tooltip": [
          {"field": "title", "type": "nominal", "title": "Listing Title"},
          {"field": "suburb", "type": "nominal", "title": "Suburb"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "propertyType", "type": "nominal", "title": "Type"},
          {"field": "price_display", "type": "quantitative", "title": "Rent ($/wk)"},
          {"field": "bedrooms", "type": "quantitative", "title": "Bedrooms"}
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}